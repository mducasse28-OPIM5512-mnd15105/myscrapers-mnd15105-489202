def materialize_v2(request):
import os
import json
import tempfile
import pandas as pd
from flask import Request
from google.cloud import storage

BUCKET_NAME = os.environ.get("BUCKET_NAME", "YOUR_BUCKET_NAME")
RAW_PREFIX = os.environ.get("RAW_PREFIX", "raw/")
OUTPUT_BLOB = os.environ.get("OUTPUT_BLOB", "materialized/materialized_v2.csv")

def materialize_v2(request: Request):
    client = storage.Client()
    bucket = client.bucket(BUCKET_NAME)

    frames = []

    for blob in client.list_blobs(BUCKET_NAME, prefix=RAW_PREFIX):
        if not blob.name.endswith(".json"):
            continue

        try:
            content = blob.download_as_text()
            obj = json.loads(content)

            if isinstance(obj, list):
                df = pd.DataFrame(obj)
            elif isinstance(obj, dict):
                df = pd.DataFrame([obj])
            else:
                continue

            frames.append(df)

        except Exception as e:
            print(f"Skipping {blob.name}: {e}")

    if not frames:
        return ("No valid data found.", 200)

    final_df = pd.concat(frames, ignore_index=True, sort=False)

    with tempfile.NamedTemporaryFile(mode="w", suffix=".csv", delete=False) as tmp:
        final_df.to_csv(tmp.name, index=False)
        tmp_path = tmp.name

    bucket.blob(OUTPUT_BLOB).upload_from_filename(tmp_path)
    os.remove(tmp_path)

    return (f"materialize-v2 complete: {len(final_df)} rows", 200)

